{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Minerês",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#types" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#numbers" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.mineres",
          "match": "//.*$"
        },
        {
          "name": "comment.block.mineres",
          "begin": "\\bcauso\\b",
          "end": "\\bfim do causo\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.mineres",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.mineres",
          "match": "\\\\."
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mineres",
          "match": "\\b(trem_di_numeru|trem_cum_virgula|trem_discrita|trem_discolhe|trosso)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mineres",
          "match": "\\b(uai_se|uai_senão|roda_esse_trem|enquanto_tiver_trem|dependenu|du_casu|ta_bao|para_o_trem|toca_o_trem|bora_cumpade|simbora|cabo|cabô|uai)\\b"
        },
        {
          "name": "support.function.mineres",
          "match": "\\b(xove|oia_proce_ve|ola_proce_ve)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.mineres",
          "match": "\\b(fica_assim_entao|neh_nada|mema_coisa|quarque_um|vam_marca|tamem|um_o_oto|veiz|sob)\\b"
        },
        {
          "name": "keyword.operator.symbol.mineres",
          "match": "(\\+|-|%|/|<|>|<=|>=|<>|\\*)"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.mineres",
          "match": "\\b0x[a-fA-F0-9]+\\b"
        },
        {
          "name": "constant.numeric.float.mineres",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.mineres",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.mineres"
        }
      ]
    }
  },
  "scopeName": "source.mineres"
}