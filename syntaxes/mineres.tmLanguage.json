{
    "name": "Minerês",
    "scopeName": "source.mineres",
    "fileTypes": ["uai"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#chars" },
        { "include": "#numbers" },
        { "include": "#keywords-types" },
        { "include": "#keywords-control" },
        { "include": "#keywords-flow" },
        { "include": "#keywords-logical" },
        { "include": "#keywords-arithmetic" },
        { "include": "#keywords-relational" },
        { "include": "#keywords-io" },
        { "include": "#keywords-boolean" },
        { "include": "#keywords-scope" },
        { "include": "#operators-symbolic" },
        { "include": "#identifiers" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.block.mineres",
                    "begin": "\\bcauso\\b",
                    "end": "\\bfim do causo\\b",
                    "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.mineres" } },
                    "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.mineres" } }
                },
                {
                    "name": "comment.line.double-slash.mineres",
                    "match": "//.*$"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.mineres",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                { "name": "constant.character.escape.mineres", "match": "\\\\." }
            ]
        },
        "chars": {
            "name": "string.quoted.single.mineres",
            "match": "'[^'\\\\]'"
        },
        "numbers": {
            "patterns": [
                { "name": "constant.numeric.hex.mineres",    "match": "\\b0[xX][0-9a-fA-F]+\\b" },
                { "name": "constant.numeric.octal.mineres",  "match": "\\b0[0-7]+\\b" },
                { "name": "constant.numeric.float.mineres",  "match": "\\b[0-9]+\\.[0-9]+\\b" },
                { "name": "constant.numeric.integer.mineres","match": "\\b[0-9]+\\b" }
            ]
        },
        "keywords-types": {
            "name": "storage.type.mineres",
            "match": "\\b(trem_di_numeru|trem_cum_virgula|trem_discrita|trem_discolhe|trosso)\\b"
        },
        "keywords-control": {
            "name": "keyword.control.mineres",
            "match": "\\b(uai_se|uai_senao|roda_esse_trem|enquanto_tiver_trem|dependenu|du_casu|uai_so)\\b"
        },
        "keywords-flow": {
            "name": "keyword.control.flow.mineres",
            "match": "\\b(ta_bao|para_o_trem|toca_o_trem|bora_cumpade|main)\\b"
        },
        "keywords-logical": {
            "name": "keyword.operator.logical.mineres",
            "match": "\\b(tamem|quarque_um|vam_marca|um_o_oto)\\b"
        },
        "keywords-arithmetic": {
            "name": "keyword.operator.arithmetic.mineres",
            "match": "\\b(veiz|sob)\\b"
        },
        "keywords-relational": {
            "name": "keyword.operator.relational.mineres",
            "match": "\\b(fica_assim_entao|mema_coisa|neh_nada)\\b"
        },
        "keywords-io": {
            "name": "support.function.mineres",
            "match": "\\b(oia_proce_ve|xove)\\b"
        },
        "keywords-boolean": {
            "name": "constant.language.boolean.mineres",
            "match": "\\b(eh|num_eh)\\b"
        },
        "keywords-scope": {
            "name": "keyword.other.scope.mineres",
            "match": "\\b(simbora|cabo|uai)\\b"
        },
        "operators-symbolic": {
            "patterns": [
                { "name": "keyword.operator.comparison.mineres", "match": "(<=|>=|<|>)" },
                { "name": "keyword.operator.arithmetic.mineres", "match": "(\\+|-|%|/)" }
            ]
        },
        "identifiers": {
            "name": "variable.other.mineres",
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
    }
}