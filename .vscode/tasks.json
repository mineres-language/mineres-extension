{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Rodar Minerês (WSL/Linux)",
            "type": "shell",
            "command": "gcc transpila.c -o transpila && ./transpila ${fileBasename} && gcc saida.c -o trem_final && ./trem_final",
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "windows": {
                "options": {
                    "shell": {
                        "executable": "bash.exe",
                        "args": [
                            "-c"
                        ]
                    }
                }
            },
            "problemMatcher": []
        },
        {
            "label": "Rodar Minerês (Windows)",
            "type": "shell",
            "command": "gcc transpila.c -o transpila.exe ; if ($?) { ./transpila.exe ${fileBasename} } ; if ($?) { gcc saida.c -o trem_final.exe } ; if ($?) { ./trem_final.exe }",
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}