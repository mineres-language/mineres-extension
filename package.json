{
    "name": "mineres",
    "displayName": "Minerês",
    "description": "Suporte oficial para a linguagem Minerês — sintaxe, ícones e execução direta de arquivos .uai.",
    "version": "2.0.4",
    "publisher": "grupo-mineres",
    "icon": "icons/icon.png",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mineres-language/mineres-extension.git"
    },
    "engines": {
        "vscode": "^1.120.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:mineres"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "mineres",
                "aliases": [
                    "Minerês",
                    "mineres"
                ],
                "extensions": [
                    ".uai"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/file-icon.png",
                    "dark": "./icons/file-icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "mineres",
                "scopeName": "source.mineres",
                "path": "./syntaxes/mineres.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "mineres.executar",
                "title": "Minerês: Executar",
                "icon": "$(play)"
            }
        ],
        "keybindings": [
            {
                "command": "mineres.executar",
                "key": "ctrl+shift+b",
                "when": "editorLangId == mineres"
            }
        ],
        "menus": {
            "editor/title/run": [
                {
                    "command": "mineres.executar",
                    "when": "editorLangId == mineres",
                    "group": "navigation"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "tsc -p ./",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^20.19.41",
        "@types/vscode": "^1.120.0",
        "typescript": "^5.9.3"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/mineres-language/mineres-extension/issues"
    },
    "homepage": "https://github.com/mineres-language/mineres-extension#readme"
}